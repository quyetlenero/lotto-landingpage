{
  "name": "messenger-ai-bot",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:webhook": "npm run dev --workspace apps/webhook",
    "dev:worker": "npm run dev --workspace apps/worker",
    "db:generate": "npm run generate --workspace packages/db",
    "db:migrate": "npm run migrate --workspace packages/db",
    "db:seed": "tsx scripts/seed.ts",
    "sla:monitor": "npm run sla --workspace apps/worker"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
