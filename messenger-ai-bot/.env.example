# --- Database ---
DATABASE_URL="postgresql://messenger_bot:messenger_bot@localhost:5432/messenger_bot"

# --- Redis / Queue ---
REDIS_URL="redis://localhost:6379"

# --- Facebook App (shared across all pages subscribed to this app) ---
FB_APP_SECRET=""
FB_WEBHOOK_VERIFY_TOKEN="choose-a-random-string"
# API version used for all Graph API calls (Send API, etc.)
FB_GRAPH_API_VERSION="v21.0"

# --- Anthropic ---
ANTHROPIC_API_KEY=""
CLAUDE_PRIMARY_MODEL="claude-sonnet-5"
CLAUDE_FALLBACK_MODEL="claude-haiku-4-5"
CLAUDE_REQUEST_TIMEOUT_MS="8000"

# --- Notifications ---
TELEGRAM_BOT_TOKEN=""
# Separate channel from per-brand sales chats, used only for SLA breach alerts
TELEGRAM_ENGINEERING_CHAT_ID=""
RESEND_API_KEY=""
NOTIFICATION_EMAIL_FROM="alerts@yourdomain.com"

# --- Ops ---
SLA_THRESHOLD_SECONDS="60"
PORT="3000"

# --- Customer insight analytics (apps/worker/src/insightExtraction.ts + generateWeeklyReport.ts) ---
# Hours of inactivity before a conversation is considered "idle" and analyzed for insight.
CONVERSATION_IDLE_HOURS="6"
# Max idle conversations analyzed per insights:extract run (bounds cost/runtime per invocation).
INSIGHT_EXTRACTION_BATCH_LIMIT="200"
CLAUDE_INSIGHT_MODEL="claude-sonnet-5"
CLAUDE_INSIGHT_TIMEOUT_MS="20000"
# Reporting window for insights:report — defaults to weekly.
REPORT_PERIOD_DAYS="7"
CLAUDE_REPORT_MODEL="claude-sonnet-5"
CLAUDE_REPORT_TIMEOUT_MS="30000"

# --- Website chat widget (apps/webhook/src/routes/website.ts + public/widget.js) ---
# Comma-separated list of origins allowed to call POST /chat/website (CORS). No wildcard —
# list every brand site domain explicitly, e.g. "https://lottosports.vn,https://www.lottosports.vn"
WEBSITE_WIDGET_ALLOWED_ORIGINS=""
WIDGET_RATE_LIMIT_MAX="20"
WIDGET_RATE_LIMIT_WINDOW_MS="60000"
