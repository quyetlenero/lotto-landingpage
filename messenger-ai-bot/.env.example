# --- Database ---
DATABASE_URL="postgresql://messenger_bot:messenger_bot@localhost:5432/messenger_bot"

# --- Redis / Queue ---
REDIS_URL="redis://localhost:6379"

# --- Facebook App (shared across all pages subscribed to this app) ---
FB_APP_SECRET=""
FB_WEBHOOK_VERIFY_TOKEN="choose-a-random-string"
# API version used for all Graph API calls (Send API, etc.)
FB_GRAPH_API_VERSION="v21.0"

# --- Anthropic ---
ANTHROPIC_API_KEY=""
CLAUDE_PRIMARY_MODEL="claude-sonnet-5"
CLAUDE_FALLBACK_MODEL="claude-haiku-4-5"
CLAUDE_REQUEST_TIMEOUT_MS="8000"

# --- Notifications ---
TELEGRAM_BOT_TOKEN=""
# Separate channel from per-brand sales chats, used only for SLA breach alerts
TELEGRAM_ENGINEERING_CHAT_ID=""
RESEND_API_KEY=""
NOTIFICATION_EMAIL_FROM="alerts@yourdomain.com"

# --- Ops ---
SLA_THRESHOLD_SECONDS="60"
PORT="3000"
